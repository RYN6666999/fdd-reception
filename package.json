{
  "name": "fdd-reception",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "guard:specs": "node guards/check-specs.mjs",
    "guard:contracts": "node guards/check-contracts.mjs",
    "guard:types": "npx tsc --noEmit",
    "guard:lint": "npx eslint contracts/ functions/ --ext .ts",
    "guard:all": "npm run guard:specs && npm run guard:contracts && npm run guard:types && npm run guard:lint",
    "smoke": "bash scripts/smoke-test.sh",
    "deploy": "npx wrangler deploy && npm run smoke",
    "dev": "npx wrangler dev"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "typescript": "^5.9.3",
    "wrangler": "^3.0.0",
    "zod": "^4.4.3"
  }
}
