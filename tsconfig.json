{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "types": ["bun-types"],
    "paths": {
      "@contracts/*": ["./contracts/*"]
    }
  },
  "include": ["contracts/**/*", "server/**/*", "guards/**/*"]
}
